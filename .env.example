# ── ClickHouse ──────────────────────────────────
CLICKHOUSE_ADDR=clickhouse:9000
CLICKHOUSE_DATABASE=asstats
CLICKHOUSE_USER=asstats
CLICKHOUSE_PASSWORD=changeme-use-a-strong-password

# ── Collector ──────────────────────────────────
COLLECTOR_LISTEN_NETFLOW=:2055
COLLECTOR_LISTEN_SFLOW=:6343
COLLECTOR_BATCH_SIZE=10000
COLLECTOR_FLUSH_INTERVAL=5s
COLLECTOR_WORKERS=4

# Your public AS number (optional but recommended).
# When set, the collector fetches your announced prefixes from RIPEstat
# and remaps private AS numbers (64512-65534) to your public AS on matching flows.
LOCAL_AS=

# ── API Server ─────────────────────────────────
API_LISTEN_ADDR=:8080
API_CORS_ORIGINS=https://as-stats.example.com

# ── Authentication (OIDC) ──────────────────────
AUTH_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=https://as-stats.example.com/auth/callback
OIDC_SCOPES=openid profile email

# ── Optional features ──────────────────────────
# Detailed flow log: keeps full per-tuple flow records (src/dst IP+port,
# protocol, TCP flags) in the flows_log table for forensic search.
# Default retention: 180 days. Estimate +250 GB / 6mo at 1:1000 sampling
# on a 1 Gbps link. Enables /flows/search API and Flow Search UI page.
FEATURE_FLOW_SEARCH=false

# Port and protocol statistics: aggregates flows by (proto, port) into
# the traffic_by_port table for "Top Ports" and "Top Protocols" views.
# Lightweight (~5 MB/day). Enables /top/protocol and /top/port endpoints.
FEATURE_PORT_STATS=false

# DDoS detection / alert engine: runs a goroutine in the collector that
# evaluates configurable rules against pre-aggregated hot tables every
# ALERT_EVAL_INTERVAL. Default rules are seeded on first startup.
# Enables the /alerts dashboard, alert badge in the header, and admin
# rule/webhook management.
FEATURE_ALERTS=false

# Alert engine tuning (only used when FEATURE_ALERTS=true).
ALERT_EVAL_INTERVAL=30s
ALERT_STALE_THRESHOLD=5m
